{
  "manifest_version": 3,
  "name": "Upwork Portfolio Assistant",
  "description": "Helps you fill your own Upwork portfolio entries from saved portfolio drafts.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.upwork.com/*", "https://api.groq.com/*"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Portfolio Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
